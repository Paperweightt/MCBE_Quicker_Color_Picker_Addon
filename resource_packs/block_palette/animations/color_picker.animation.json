{
    "format_version": "1.8.0",
    "animations": {
        "animation.color_picker.sl": {
            "loop": true,
            "bones": {
                "saturationAndLightness": {
                    "position": ["query.property('qbp:blockx')", "query.property('qbp:blocky')", 0]
                }
            }
        },
        "animation.color_picker.hue": {
            "loop": true,
            "bones": {
                "hueSlider": {
                    "position": [0, "query.property('qbp:hue')", 0]
                }
            }
        },
        "animation.rotate": {
            "loop": true,
            "bones": {
                "head": {
                    "rotation": [0, "query.property('qbp:rotatey')", 0]
                }
            }
        }
    }
}
